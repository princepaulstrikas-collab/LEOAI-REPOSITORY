rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Basic secure rule: users can only read/write their own data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // Add public read/write permission for real-time messaging collections
    match /messenger_messages/{messageId} {
      allow read, write: if true;
    }

    match /messenger_contacts/{contactId} {
      allow read, write: if true;
    }
    
    // Explicit deny for everything else (this is the default, but good to be clear)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
